local AutoCollect = false
local AutoClean = false
local AutoCook = false
local AutoServe = false
local IsShrunk = false

-- 创建黄金样式按钮的函数
local function createGoldButton(name, text, positionY)
    local Btn = Instance.new("TextButton")
    Btn.Name = name
    Btn.Size = UDim2.new(0, 190, 0, 40)
    Btn.Position = UDim2.new(0, 20, 0, positionY)
    Btn.BackgroundColor3 = Color3.fromRGB(80, 65, 30) -- 按钮暗金底色
    Btn.BorderSizePixel = 1
    Btn.BorderColor3 = Color3.fromRGB(218, 165, 32) -- 闪金边框
    Btn.Text = text .. " [关]"
    Btn.TextColor3 = Color3.fromRGB(255, 245, 200)
    Btn.TextSize = 14
    Btn.Font = Enum.Font.SourceSansBold
    Btn.Parent = ContentFrame
    
    local BtnCorner = Instance.new("UICorner")
    BtnCorner.CornerRadius = UDim.new(0, 6)
    BtnCorner.Parent = Btn
    return Btn
end

-- 生成4大核心功能按钮
local CollectBtn = createGoldButton("CollectBtn", "自动收集金钱", 15)
local CleanBtn   = createGoldButton("CleanBtn", "自动清理盘子", 65)
local CookBtn    = createGoldButton("CookBtn", "自动制作料理", 115)
