-- ==========================================
-- 按钮控制事件逻辑
-- ==========================================

-- 关闭面板
CloseBtn.MouseButton1Click:Connect(function()
    ScreenGui:Destroy()
end)

-- 收缩与展开面板
ShrinkBtn.MouseButton1Click:Connect(function()
    if IsShrunk then
        MainFrame:TweenSize(UDim2.new(0, 230, 0, 340), "Out", "Quint", 0.3, true)
        ContentFrame.Visible = true
        ShrinkBtn.Text = "—"
        IsShrunk = false
    else
        MainFrame:TweenSize(UDim2.new(0, 230, 0, 40), "Out", "Quint", 0.3, true)
        ContentFrame.Visible = false
        ShrinkBtn.Text = "口"
        IsShrunk = true
    end
end)

-- 统一开关颜色切换逻辑
local function toggleVisual(btn, state, text)
    if state then
        btn.Text = text .. " [开]"
        btn.BackgroundColor3 = Color3.fromRGB(184, 134, 11) -- 激活时变成亮金/深金
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    else
        btn.Text = text .. " [关]"
        btn.BackgroundColor3 = Color3.fromRGB(80, 65, 30)
        btn.TextColor3 = Color3.fromRGB(255, 245, 200)
    end
end

CollectBtn.MouseButton1Click:Connect(function() AutoCollect = not AutoCollect toggleVisual(CollectBtn, AutoCollect, "自动收集金钱") end)
CleanBtn.MouseButton1Click:Connect(function() AutoClean = not AutoClean toggleVisual(CleanBtn, AutoClean, "自动清理盘子") end)
CookBtn.MouseButton1Click:Connect(function() AutoCook = not AutoCook toggleVisual(CookBtn, AutoCook, "自动制作料理") end)
ServeBtn.MouseButton1Click:Connect(function() AutoServe = not AutoServe toggleVisual(ServeBtn, AutoServe, "自动帮忙上菜") end)

-- ==========================================
-- 核心挂机驱动逻辑（每0.5秒循环检测）
-- ==========================================
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

task.spawn(function()
    while true do
        task.wait(0.5)
        
        -- 获取玩家本人的餐厅地块
        local myTycoon = workspace.Tycoons:FindFirstChild(LocalPlayer.Name .. "'s Restaurant") or workspace.Tycoons:FindFirstChild(LocalPlayer.Name)
        
        if myTycoon then
            
            -- 1. 自动收集金钱
            if AutoCollect then
                for _, obj in pairs(myTycoon:GetDescendants()) do
                    if obj.Name == "Coin" or obj.Name == "Cash" or obj.Name == "Bill" then
                        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                            obj.CFrame = LocalPlayer.Character.HumanoidRootPart.CFrame
                        end
                    end
                end
            end
            
            -- 2. 自动清理盘子
            if AutoClean then
                for _, obj in pairs(myTycoon:GetDescendants()) do
                    if obj.Name == "DirtyPlate" or obj.Name == "Plate" then
                        local sink = myTycoon:FindFirstChild("Sink") or myTycoon:FindFirstChild("Dishwasher") or myTycoon:FindFirstChild("Kitchen")
                        if sink then
                            obj.CFrame = sink.CFrame
                        end
                    end
                end
            end
            
            -- 3. 自动制作料理（寻找厨房未完成的食物并触发完成）
            if AutoCook then
                for _, obj in pairs(myTycoon:GetDescendants()) do
                    -- 寻找正在炉灶上制作或等待加热的食物对象
                    if obj.Name == "CookingFood" or obj.Name == "Order" or obj.Name == "Stove" then
                        -- 触发游戏内灶台或料理的进度事件
                        local duration = obj:FindFirstChild("Duration") or obj:FindFirstChild("Progress")
                        if duration and duration:IsA("ValueBase") then
                            duration.Value = duration.Value + 10 -- 加快进度
                        end
                        -- 尝试寻找游戏内网络事件直接完成烹饪
                        local network = game:GetService("ReplicatedStorage"):FindFirstChild("Network") or game:GetService("ReplicatedStorage"):FindFirstChild("Events")
                        if network and network:FindFirstChild("Cook") then
                            network.Cook:FireServer(obj)
                        end
                    end
                end
            end
            
            -- 4. 自动帮忙上菜给客人
            if AutoServe then
                for _, obj in pairs(myTycoon:GetDescendants()) do
                    -- 寻找已经做好的食物 (Food / Meal)
                    if obj.Name == "ReadyFood" or obj.Name == "Meal" or obj.Name == "Food" then
                        -- 寻找大厅里点了这道菜对应的顾客或桌子
                        for _, customer in pairs(myTycoon:GetDescendants()) do
                            if customer.Name == "Customer" and customer:FindFirstChild("Order") then
                                -- 瞬间将食物传送到顾客面前完成服务
                                obj.CFrame = customer.CFrame
                                break
                            end
                        end
                    end
                end
            end
            
        end
    end
end)
